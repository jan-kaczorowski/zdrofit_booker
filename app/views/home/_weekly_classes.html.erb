<turbo-frame id="weekly-classes-container">
  <div class="space-y-4">
    <% if next_5_days.present? && next_5_days.any? %>
      <%# Day tabs — pill style %>
      <div class="flex flex-wrap gap-2" data-dashboard-target="dayTabs">
        <% next_5_days.each do |day| %>
          <% class_count = (classes_by_date[day[:date]] || []).count %>
          <button
            data-action="dashboard#selectDay"
            data-date="<%= day[:date] %>"
            class="px-3.5 py-1.5 rounded-full font-medium text-xs transition-all
              <%= day[:date] == selected_date ? 'bg-accent text-white shadow-glow' : 'bg-surface-nested text-txt-secondary hover:bg-surface-hover' %>"
          >
            <%= day[:label] %>
            <% if class_count > 0 %>
              <span class="ml-0.5 <%= day[:date] == selected_date ? 'text-white/60' : 'text-txt-muted' %>">(<%= class_count %>)</span>
            <% end %>
          </button>
        <% end %>
      </div>

      <%# Search %>
      <div class="relative">
        <%= icon(:search, css: "absolute left-3 top-2.5 w-4 h-4 text-txt-muted") %>
        <input
          type="text"
          id="class-search"
          placeholder="Szukaj zajęć lub trenera..."
          class="w-full px-3.5 py-2.5 pl-9 rounded-xl bg-surface-nested text-sm text-txt placeholder-txt-muted focus:outline-none focus:ring-2 focus:ring-accent/20 transition-all font-body"
        >
      </div>

      <%# Classes for selected day %>
      <% selected_day = next_5_days.find { |d| d[:date] == selected_date } %>
      <% if selected_day %>
        <% day_classes = (classes_by_date[selected_date] || []).sort_by { |c| DateTime.parse(c["StartTime"]) } %>
        <% if day_classes.any? %>
          <div class="space-y-2" data-dashboard-target="classesContainer">
            <% day_classes.each do |class_data| %>
              <% start_time = DateTime.parse(class_data["StartTime"].to_s) %>
              <% is_booked = class_data['BookingId'].present? %>
              <div class="flex items-center gap-4 p-3.5 rounded-2xl bg-surface-nested hover:bg-surface-hover transition-all class-row"
                   data-class-name="<%= class_data["Name"].downcase %>">

                <%# Time block %>
                <div class="flex-shrink-0 text-center w-14">
                  <div class="text-lg font-bold text-accent leading-tight"><%= start_time.strftime("%H:%M") %></div>
                  <div class="text-[10px] font-medium text-txt-muted uppercase tracking-wider font-body">60 min</div>
                </div>

                <%# Divider line %>
                <div class="w-px h-10 bg-surface-hover flex-shrink-0"></div>

                <%# Class info %>
                <div class="flex-1 min-w-0">
                  <div class="font-semibold text-txt text-sm"><%= class_data["Name"] %></div>
                  <div class="flex items-center gap-1.5 mt-0.5">
                    <%= icon(:user, css: "w-3 h-3 text-txt-muted") %>
                    <span class="text-xs text-txt-secondary font-body"><%= class_data["Trainer"]&.upcase %></span>
                  </div>
                  <% if is_booked %>
                    <div class="flex items-center gap-1 text-[10px] text-success mt-0.5 font-medium font-body">
                      <%= icon(:check, css: "w-2.5 h-2.5") %> Zaplanowano
                    </div>
                  <% end %>
                </div>

                <%# Action button %>
                <button
                  data-action="dashboard#bookClass"
                  data-booking-id="<%= class_data['BookingId'] %>"
                  data-class-id="<%= class_data["Id"] %>"
                  data-club-id="<%= params[:club_id] %>"
                  data-next-occurrence="<%= class_data["StartTime"] %>"
                  data-class-name="<%= class_data["Name"] %>"
                  data-trainer-name="<%= class_data["TrainerName"] || class_data["Trainer"] %>"
                  data-timetable-id="<%= class_data["TimeTableId"] %>"
                  class="flex-shrink-0 transition-all
                    <%= is_booked ? 'w-8 h-8 rounded-full bg-success-light text-success flex items-center justify-center' : 'px-3 py-1.5 rounded-full bg-accent-light text-accent text-xs font-medium hover:bg-accent-medium hover:scale-[1.02]' %>"
                  <%= 'disabled' if is_booked %>
                >
                  <% if is_booked %>
                    <%= icon(:check, css: "w-4 h-4") %>
                  <% else %>
                    Zapisz się
                  <% end %>
                </button>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-6 text-txt-muted">
            <%= icon(:calendar_empty, css: "w-8 h-8 mx-auto mb-2") %>
            <p class="text-sm font-body">Brak zajęć w tym dniu.</p>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="text-center py-6 text-txt-muted">
        <%= icon(:dumbbell, css: "w-8 h-8 mx-auto mb-2") %>
        <p class="text-sm font-body">Wybierz klub, aby zobaczyć zajęcia.</p>
      </div>
    <% end %>
  </div>
</turbo-frame>
