<turbo-frame id="weekly-classes-container">
  <div class="space-y-4">
    <% if next_5_days.present? && next_5_days.any? %>
      <%# Day tabs %>
      <div class="flex flex-wrap gap-2" data-dashboard-target="dayTabs">
        <% next_5_days.each do |day| %>
          <% class_count = (classes_by_date[day[:date]] || []).count %>
          <button
            data-action="dashboard#selectDay"
            data-date="<%= day[:date] %>"
            class="px-4 py-2 rounded-lg font-medium text-sm transition-colors
              <%= day[:date] == selected_date ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>"
          >
            <%= day[:label] %>
            <% if class_count > 0 %>
              <span class="ml-1 text-xs <%= day[:date] == selected_date ? 'text-indigo-200' : 'text-gray-500' %>">(<%= class_count %>)</span>
            <% end %>
          </button>
        <% end %>
      </div>

      <%# Search input %>
      <div class="relative">
        <input
          type="text"
          id="class-search"
          placeholder="Search classes..."
          class="w-full px-4 py-2 pl-10 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
        >
        <svg class="absolute left-3 top-2.5 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>

      <%# Classes for selected day %>
      <% selected_day = next_5_days.find { |d| d[:date] == selected_date } %>
      <% if selected_day %>
        <h3 class="text-lg font-semibold text-gray-800 border-b-2 border-indigo-500 pb-2">
          <%= selected_day[:formatted].upcase %>
        </h3>

        <% day_classes = (classes_by_date[selected_date] || []).sort_by { |c| DateTime.parse(c["StartTime"]) } %>
        <% if day_classes.any? %>
          <div class="space-y-2" data-dashboard-target="classesContainer">
            <% day_classes.each do |class_data| %>
              <% start_time = DateTime.parse(class_data["StartTime"].to_s) %>
              <% is_booked = class_data['BookingId'].present? %>
              <div class="flex items-center justify-between p-3 bg-white border border-gray-200 rounded-lg hover:border-indigo-300 transition-colors class-row"
                   data-class-name="<%= class_data["Name"].downcase %>">
                <div class="flex items-center gap-4">
                  <div class="text-lg font-semibold text-indigo-600 w-16">
                    <%= start_time.strftime("%H:%M") %>
                  </div>
                  <div>
                    <div class="font-medium text-gray-900"><%= class_data["Name"] %></div>
                    <div class="text-sm text-gray-500">Trainer: <%= class_data["Trainer"]&.upcase %></div>
                    <% if is_booked %>
                      <div class="text-xs text-green-600 mt-0.5">✓ Auto-booking scheduled</div>
                    <% end %>
                  </div>
                </div>

                <button
                  data-action="dashboard#bookClass"
                  data-booking-id="<%= class_data['BookingId'] %>"
                  data-class-id="<%= class_data["Id"] %>"
                  data-club-id="<%= params[:club_id] %>"
                  data-next-occurrence="<%= class_data["StartTime"] %>"
                  data-class-name="<%= class_data["Name"] %>"
                  data-trainer-name="<%= class_data["TrainerName"] || class_data["Trainer"] %>"
                  class="flex items-center justify-center w-10 h-10 rounded-full transition-colors
                    <%= is_booked ? 'bg-green-100 text-green-600' : 'bg-indigo-100 text-indigo-600 hover:bg-indigo-200' %>"
                  <%= 'disabled' if is_booked %>
                >
                  <% if is_booked %>
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  <% else %>
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                  <% end %>
                </button>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-8 text-gray-500">
            <div class="text-4xl mb-2">📅</div>
            <p>No classes scheduled for this day.</p>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="text-center py-8 text-gray-500">
        <div class="text-4xl mb-2">🏋️</div>
        <p>Select a club to view available classes.</p>
      </div>
    <% end %>
  </div>
</turbo-frame>
