<%# Content container %>
<div class="max-w-6xl mx-auto space-y-8" data-controller="dashboard">

  <%# Hero Section %>
  <div class="pt-4">
    <div class="flex items-start justify-between flex-wrap gap-4">
      <div>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-txt tracking-tight">
          Witaj!
        </h1>
        <p class="text-txt-secondary mt-1 text-base font-body max-w-lg">
          Twoja podróż do szczytowej formy trwa.
          <% if @active_booking_count > 0 %>
            Mamy dla Ciebie przygotowane <span class="text-accent font-semibold"><%= @active_booking_count %></span> automatyczne rezerwacje na ten tydzień.
          <% else %>
            Zaplanuj automatyczne rezerwacje poniżej.
          <% end %>
        </p>
      </div>
    </div>
  </div>

  <%# Two Column Layout %>
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-6">

    <%# Left Column — Auto-Bookings (2/5) %>
    <div class="lg:col-span-2 space-y-6">
      <div class="rounded-4xl p-6 bg-surface-card shadow-card">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-base font-bold text-accent flex items-center gap-2">
            <%= icon(:calendar, css: "w-5 h-5 text-accent") %>
            Twoje Rezerwacje
          </h2>
          <button class="text-txt-muted hover:text-txt-secondary transition-colors" title="Automatyczne rezerwacje uruchamiają się 2 dni przed zajęciami">
            <%= icon(:info, css: "w-4 h-4") %>
          </button>
        </div>

        <turbo-frame id="ongoing-bookings-container" src="/ongoing_bookings">
          <div class="flex justify-center py-8">
            <div class="animate-spin rounded-full h-7 w-7 border-b-2 border-accent"></div>
          </div>
        </turbo-frame>
      </div>
    </div>

    <%# Right Column — Class Browser (3/5) %>
    <div class="lg:col-span-3" id="new-booking">
      <div class="rounded-4xl p-6 bg-surface-card shadow-card">
        <h2 class="text-base font-bold text-accent flex items-center gap-2 mb-5">
          <%= icon(:search, css: "w-5 h-5 text-accent") %>
          Przeglądarka Zajęć
        </h2>

        <% if flash[:error] %>
          <div class="bg-danger-light text-danger px-4 py-3 rounded-2xl mb-4 text-sm font-body" role="alert">
            <%= flash[:error] %>
          </div>
        <% end %>

        <%# City and Club dropdowns — side by side %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-5">
          <div class="w-full">
            <label class="block text-xs font-medium text-txt-muted mb-1.5 uppercase tracking-wider font-body">Miasto</label>
            <div class="dropdown relative">
              <input type="text" id="city-dropdown" placeholder="Wybierz miasto..."
                class="w-full px-3.5 py-2.5 rounded-xl bg-surface-nested text-sm text-txt placeholder-txt-muted focus:outline-none focus:ring-2 focus:ring-accent/20 transition-all font-body"
                data-dashboard-target="cityButton"
                data-action="focus->dashboard#showCityDropdown input->dashboard#filterCityDropdown keydown->dashboard#handleDropdownKeydown">
              <div class="dropdown-menu hidden" role="menu" data-dashboard-target="cityMenu">
                <ul class="py-1">
                  <% @clubs.map { |club| club.dig('City', 'Name') }.uniq.sort.map(&:strip).each do |city| %>
                    <li>
                      <div class="dropdown-item" data-value="<%= city %>" data-action="click->dashboard#selectCity"><%= city %></div>
                    </li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>

          <div class="w-full <%= 'hidden' unless @user.last_city_id.present? %>" id="clubs-container" data-dashboard-target="clubsContainer">
            <label class="block text-xs font-medium text-txt-muted mb-1.5 uppercase tracking-wider font-body">Klub</label>
            <div class="dropdown relative">
              <input type="text" id="club-dropdown" placeholder="Wybierz klub..."
                class="w-full px-3.5 py-2.5 rounded-xl bg-surface-nested text-sm text-txt placeholder-txt-muted focus:outline-none focus:ring-2 focus:ring-accent/20 transition-all font-body"
                data-dashboard-target="clubButton"
                data-action="focus->dashboard#showClubDropdown input->dashboard#filterClubDropdown keydown->dashboard#handleDropdownKeydown">
              <div class="dropdown-menu hidden" role="menu" data-dashboard-target="clubMenu">
                <ul class="py-1">
                  <% @clubs.each do |club| %>
                    <li>
                      <div class="dropdown-item" data-value="<%= club['Id'] %>" data-city="<%= club.dig('City', 'Name').strip %>" data-action="click->dashboard#selectClub"><%= club['Name'].strip %> - <%= club['Address'].strip %></div>
                    </li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        </div>

        <% if @clubs.blank? || !@clubs.respond_to?(:each) %>
          <div class="bg-amber-50 text-amber-700 px-4 py-3 rounded-2xl text-sm font-body" role="alert">
            <strong class="font-bold">Uwaga:</strong>
            Nie udało się załadować klubów. Spróbuj odświeżyć stronę.
          </div>
        <% end %>

        <%# Weekly classes container %>
        <turbo-frame id="weekly-classes-container" class="hidden" src="/weekly_classes">
          <div class="flex justify-center py-8">
            <div class="animate-spin rounded-full h-7 w-7 border-b-2 border-accent"></div>
          </div>
        </turbo-frame>

        <% unless params[:club_id].present? || @user.last_club_id.present? %>
          <div class="text-center py-10 text-txt-muted">
            <%= icon(:dumbbell, css: "w-10 h-10 mx-auto mb-3") %>
            <p class="text-sm font-body">Wybierz miasto i klub, aby zobaczyć dostępne zajęcia.</p>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="h-8"></div>
</div>
