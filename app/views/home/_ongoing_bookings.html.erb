<turbo-frame id="ongoing-bookings-container">
  <div class="space-y-3">
    <% if pending_bookings.any? %>
      <% pending_bookings.each do |booking| %>
        <% event = booking.current_event %>
        <% is_confirmed = event.status == "booked" %>
        <% prev = booking.previous_completed_event %>
        <div class="rounded-2xl p-4 bg-surface-nested transition-all hover:bg-surface-hover group">
          <div class="flex items-start gap-3">
            <%# Circular icon — green if confirmed, accent if pending %>
            <div class="flex-shrink-0 w-10 h-10 rounded-full <%= is_confirmed ? 'bg-success-light' : 'bg-accent-light' %> flex items-center justify-center mt-0.5">
              <% if is_confirmed %>
                <%= icon(:check, css: "w-5 h-5 text-success") %>
              <% else %>
                <%= icon(:dumbbell, css: "w-5 h-5 text-accent") %>
              <% end %>
            </div>

            <div class="flex-1 min-w-0">
              <%# Title + status badge %>
              <div class="flex items-center gap-2 flex-wrap">
                <h3 class="font-semibold text-txt text-sm truncate"><%= booking.class_name %></h3>
                <% if is_confirmed %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-success-light text-success text-[10px] font-bold uppercase tracking-wider">
                    <%= icon(:check, css: "w-2.5 h-2.5") %> Zarezerwowano
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-accent-light text-accent text-[10px] font-bold uppercase tracking-wider">
                    <%= icon(:timer, css: "w-2.5 h-2.5") %> Oczekuje
                  </span>
                <% end %>
              </div>

              <%# Location + time %>
              <p class="text-xs text-txt-muted mt-0.5 truncate font-body">
                <%= booking.trainer_name&.upcase || "TBA" %> &middot; <%= I18n.l(event.occurrence_in_warsaw, format: "%A, %d %b") %>, <%= I18n.l(event.occurrence_in_warsaw, format: "%H:%M") %>
              </p>

              <%# Previous attempt result (only for pending events) %>
              <% if !is_confirmed && prev %>
                <p class="text-[10px] mt-0.5 font-body <%= prev.status == 'booked' ? 'text-success' : 'text-danger' %>">
                  <% if prev.status == "booked" %>
                    <%= icon(:check, css: "w-2.5 h-2.5 inline") %> Ostatnia: zarezerwowano <%= I18n.l(prev.occurrence_in_warsaw, format: "%d %b") %>
                  <% else %>
                    <%= icon(:x_circle, css: "w-2.5 h-2.5 inline") %> Ostatnia: nie udało się <%= I18n.l(prev.occurrence_in_warsaw, format: "%d %b") %>
                  <% end %>
                </p>
              <% end %>

              <%# Countdown badge %>
              <div class="flex items-center gap-2 mt-2">
                <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-lg <%= is_confirmed ? 'bg-success-light text-success' : 'bg-accent-light text-accent' %> text-xs font-medium font-body">
                  <%= icon(:timer, css: "w-3.5 h-3.5") %>
                  <%= is_confirmed ? "Potwierdzone" : event.time_until_booking %>
                </span>
              </div>
            </div>

            <%# Cancel button — visible on hover %>
            <button
              data-action="dashboard#cancelBooking"
              data-booking-id="<%= booking.id %>"
              data-class-name="<%= booking.class_name %>"
              class="flex-shrink-0 opacity-0 group-hover:opacity-100 p-1.5 text-txt-muted hover:text-danger hover:bg-danger-light rounded-full transition-all"
              title="Anuluj"
            >
              <%= icon(:x_circle, css: "w-4 h-4") %>
            </button>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-6 text-txt-muted">
        <%= icon(:inbox, css: "w-8 h-8 mx-auto mb-2") %>
        <p class="text-sm font-body">Brak rezerwacji</p>
        <p class="text-xs mt-0.5 font-body">Dodaj pierwszą poniżej</p>
      </div>
    <% end %>

    <% if failed_bookings.any? %>
      <details class="mt-2">
        <summary class="cursor-pointer px-3 py-2 bg-danger-light text-danger rounded-xl hover:bg-rose-100 transition-colors text-xs flex items-center gap-1.5 font-body">
          <%= icon(:x_circle, css: "w-3.5 h-3.5") %>
          <span class="font-medium"><%= failed_bookings.count %> nieudane</span>
        </summary>
        <div class="mt-2 space-y-2">
          <% failed_bookings.each do |booking| %>
            <% failed_event = booking.latest_failed_event %>
            <div class="rounded-xl p-3 bg-danger-light/50">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <div class="w-7 h-7 rounded-full bg-danger-light flex items-center justify-center">
                    <%= icon(:x_circle, css: "w-3.5 h-3.5 text-danger") %>
                  </div>
                  <div>
                    <h4 class="font-medium text-txt text-xs"><%= booking.class_name %></h4>
                    <p class="text-[10px] text-txt-muted font-body">
                      <%= booking.trainer_name&.upcase %>
                      <% if failed_event&.debug_info.present? %>
                        &middot; <%= failed_event.debug_info %>
                      <% end %>
                    </p>
                  </div>
                </div>
                <button
                  data-action="dashboard#cancelBooking"
                  data-booking-id="<%= booking.id %>"
                  data-class-name="<%= booking.class_name %>"
                  class="text-[10px] text-txt-muted hover:text-danger transition-colors font-body"
                >
                  Usuń
                </button>
              </div>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
</turbo-frame>
