<turbo-frame id="ongoing-bookings-container">
  <div class="space-y-4">
    <% if pending_bookings.any? %>
      <% pending_bookings.each do |booking| %>
        <div class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm hover:shadow-md transition-shadow">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <span class="text-lg">⏰</span>
                <h3 class="text-lg font-semibold text-gray-900"><%= booking.class_name %></h3>
              </div>

              <div class="mt-3 space-y-1.5 text-sm text-gray-600">
                <div class="flex items-center gap-2">
                  <span>📅</span>
                  <span><%= I18n.l(booking.next_occurrence_in_warsaw, format: "%A, %d %b o %H:%M") %></span>
                </div>
                <div class="flex items-center gap-2">
                  <span>👤</span>
                  <span>Trener: <%= booking.trainer_name&.upcase || "TBA" %></span>
                </div>
              </div>

              <div class="mt-3 p-2 bg-indigo-50 rounded-md">
                <div class="flex items-center gap-2 text-sm">
                  <span>🎯</span>
                  <span class="text-indigo-700">
                    Rezerwacja zaplanowana na:
                    <strong><%= I18n.l(booking.booking_time_in_warsaw, format: "%a, %d %b o %H:%M:%S") %></strong>
                  </span>
                </div>
                <div class="flex items-center gap-2 text-sm mt-1">
                  <span>⏱️</span>
                  <span class="text-indigo-600 font-medium"><%= booking.time_until_booking %></span>
                </div>
              </div>
            </div>

            <button
              data-action="dashboard#cancelBooking"
              data-booking-id="<%= booking.id %>"
              data-class-name="<%= booking.class_name %>"
              class="ml-4 px-3 py-1.5 text-sm font-medium text-red-600 hover:text-red-800 hover:bg-red-50 rounded-md transition-colors"
            >
              Anuluj
            </button>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-8 text-gray-500">
        <div class="text-4xl mb-2">📭</div>
        <p>Brak zaplanowanych rezerwacji.</p>
        <p class="text-sm mt-1">Wybierz klub poniżej, aby zaplanować nowe zajęcia.</p>
      </div>
    <% end %>

    <% if failed_bookings.any? %>
      <details class="mt-4">
        <summary class="cursor-pointer px-4 py-2 bg-red-50 text-red-700 rounded-lg hover:bg-red-100 transition-colors">
          <span class="font-medium">📋 Pokaż <%= failed_bookings.count %> nieudane rezerwacje</span>
        </summary>
        <div class="mt-2 space-y-2">
          <% failed_bookings.each do |booking| %>
            <div class="bg-red-50 border border-red-200 rounded-lg p-3">
              <div class="flex items-start justify-between">
                <div>
                  <div class="flex items-center gap-2">
                    <span class="text-red-500">❌</span>
                    <h4 class="font-medium text-gray-900"><%= booking.class_name %></h4>
                  </div>
                  <div class="mt-1 text-sm text-gray-600">
                    <span><%= I18n.l(booking.next_occurrence, format: "%a, %d %b o %H:%M") %></span>
                    <span class="mx-1">·</span>
                    <span><%= booking.trainer_name&.upcase %></span>
                  </div>
                  <% if booking.debug_info.present? %>
                    <div class="mt-1 text-xs text-red-600"><%= booking.debug_info %></div>
                  <% end %>
                </div>
                <button
                  data-action="dashboard#cancelBooking"
                  data-booking-id="<%= booking.id %>"
                  data-class-name="<%= booking.class_name %>"
                  class="text-sm text-gray-500 hover:text-red-600"
                >
                  Usuń
                </button>
              </div>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
</turbo-frame>
