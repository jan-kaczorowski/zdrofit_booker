<% content_for :fullscreen, "true" %>

<style>
  .bg-mesh {
    background-image: linear-gradient(135deg, #3525cd 0%, #4f46e5 50%, #0058be 100%);
    position: relative;
    overflow: hidden;
  }
  .bg-mesh::after {
    content: '';
    position: absolute;
    inset: 0;
    background: url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=2070&auto=format&fit=crop') center/cover no-repeat;
    opacity: 0.2;
    mix-blend-mode: overlay;
  }
  .glass-card {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }
</style>

<main class="flex-grow flex items-center justify-center bg-mesh relative px-4 min-h-screen">
  <%# Decorative glow blobs %>
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-indigo-700 opacity-20 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-[0%] right-[0%] w-[50%] h-[50%] bg-blue-600 opacity-30 blur-[120px] rounded-full"></div>
  </div>

  <%# Glassmorphic Login Card %>
  <div class="glass-card w-full max-w-[480px] p-8 md:p-12 rounded-3xl shadow-2xl z-10">
    <%# Header %>
    <div class="text-center mb-10">
      <div class="inline-flex items-center justify-center w-14 h-14 bg-accent text-white rounded-2xl mb-4 shadow-lg">
        <%= icon(:dumbbell, css: "w-7 h-7 text-white") %>
      </div>
      <h1 class="font-sans text-3xl font-extrabold text-accent tracking-tight mb-2">Zdrofit Booker</h1>
      <p class="text-slate-500 font-medium font-body">Twój osobisty asystent rezerwacji</p>
    </div>

    <%# Flash error %>
    <% if flash[:error] %>
      <div class="bg-danger-light text-danger px-4 py-3 rounded-2xl text-sm text-center mb-6" role="alert">
        <%= flash[:error] %>
      </div>
    <% end %>

    <%# Login Form %>
    <%= form_tag login_path, method: :post, class: "space-y-6" do %>
      <div>
        <label for="email" class="block text-sm font-semibold text-txt mb-2 px-1 font-body">E-mail</label>
        <%= email_field_tag :email, nil,
          class: "block w-full px-4 py-4 bg-white/50 border-0 focus:ring-2 focus:ring-accent/40 rounded-2xl text-txt placeholder:text-slate-400 transition-all shadow-sm font-body",
          placeholder: "Wprowadź swój e-mail" %>
      </div>

      <div>
        <label for="password" class="block text-sm font-semibold text-txt mb-2 px-1 font-body">Hasło</label>
        <%= password_field_tag :password, nil,
          class: "block w-full px-4 py-4 bg-white/50 border-0 focus:ring-2 focus:ring-accent/40 rounded-2xl text-txt placeholder:text-slate-400 transition-all shadow-sm font-body",
          placeholder: "Wprowadź hasło" %>
      </div>

      <div>
        <%= submit_tag "Zaloguj",
          class: "w-full bg-accent text-white font-bold py-4 rounded-full shadow-lg hover:scale-[1.02] active:scale-[0.98] transition-all duration-200 cursor-pointer",
          style: "box-shadow: 0 10px 30px rgba(79, 70, 229, 0.25);" %>
      </div>
    <% end %>

    <p class="text-slate-400 text-xs mt-8 text-center leading-relaxed font-body">
      Automatycznie rezerwuj zajęcia fitness w Twoich ulubionych klubach.
    </p>
  </div>
</main>
